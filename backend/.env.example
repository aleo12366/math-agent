# ============================================================
# Math Agent System - 环境变量配置
# ============================================================
# 使用方法:
#   1. 复制此文件:  copy .env.example .env
#   2. 编辑 .env 文件，填入你的实际配置
#   3. 启动后端: python main.py
# ============================================================

# [必填] Intern-S1 API 配置
# -----------------------------------------------
# API 地址 - 你的 Intern-S1 模型服务端点
# 如果使用 OpenAI 兼容接口，格式通常为:
#   https://your-server/v1/chat/completions
MATH_AGENT_API_URL=https://intern-s1-api.example.com/v1/chat/completions

# API 密钥 - 用于认证的令牌
# 获取方式:
#   方式1: InternLM 官方平台 -> 个人中心 -> API Key
#   方式2: 如果是自部署 Intern-S1，在部署配置中设置的密钥
#   方式3: 第三方平台 (如 SiliconFlow、OpenRouter 等) 的 API Key
MATH_AGENT_API_KEY=your-api-key-here

# 模型名称 - 发送给 API 的 model 字段
# 常见值:
#   Intern-S1           (官方 Intern-S1)
#   internlm2-chat-7b   (InternLM2)
#   gpt-4               (OpenAI)
#   deepseek-chat       (DeepSeek)
MATH_AGENT_MODEL_NAME=Intern-S1

# [可选] LLM 参数
# -----------------------------------------------
# Temperature: 控制输出随机性 (0.0=精确, 2.0=创造性)
MATH_AGENT_TEMPERATURE=0.7

# 最大输出 Token 数
MATH_AGENT_MAX_TOKENS=4096

# Top-P: 核采样阈值
MATH_AGENT_TOP_P=0.9

# [可选] 流水线配置
# -----------------------------------------------
# 推理模式: single(单智能体) 或 multi_debate(辩论模式)
MATH_AGENT_PIPELINE_MODE=single

# 辩论模式下的智能体数量 (1-10)
MATH_AGENT_DEBATE_AGENTS=3

# 验证失败后的最大重试次数
MATH_AGENT_MAX_RETRIES=3

# 超时时间(秒)
MATH_AGENT_TIMEOUT_SECONDS=300

# [可选] 验证阈值
# -----------------------------------------------
# 验证通过阈值 (0.0-1.0)
MATH_AGENT_VERIFICATION_THRESHOLD=0.8

# 置信度阈值 (0.0-1.0)
MATH_AGENT_CONFIDENCE_THRESHOLD=0.7

# [可选] 服务器配置
# -----------------------------------------------
# 监听地址和端口
MATH_AGENT_HOST=0.0.0.0
MATH_AGENT_PORT=8000

# 调试模式
MATH_AGENT_DEBUG=false

# 日志级别: DEBUG, INFO, WARNING, ERROR
MATH_AGENT_LOG_LEVEL=INFO